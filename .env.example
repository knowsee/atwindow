# 复制为 .env 后按需修改：cp .env.example .env

# API 根路径
# - 本地开发推荐 /api（配合 vite 代理到 backend.atwindow.com，无跨域）
# - 生产构建可用完整地址：https://backend.atwindow.com/api
VITE_API_BASE_URL=/api

# 是否启用 MSW 假数据（走正式接口时请设为 false）
VITE_USE_MSW=false

VITE_MAPBOX_ACCESS_TOKEN=

# 打单页渠道 Logo 为相对路径时拼接用（可选）
# VITE_LEGACY_ASSET_ORIGIN=https://www.atwindow.com

# 物流商 translogo：默认使用 public/images/translogo（同源）。仅当需要走 CDN 时设置完整 URL，例如：
# VITE_TRANSLOGO_ORIGIN=https://wms.atwindow.com
