/* 国家下拉宽度撑满 */
.el-select {
    width: 100%;
}

@media (max-width: 960px) {
    .fg-3 {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 640px) {

    .fg-2,
    .fg-3 {
        grid-template-columns: 1fr;
    }

    .card-body {
        padding: 16px;
    }
}

