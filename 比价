_extractCompareRateList(rateRespData) {
    const list=Array.isArray(rateRespData && rateRespData.rate_list) ? rateRespData.rate_list : [];

    const rows=list.map(item=> {
            const qidNum=Number(item.qid);
            const ch=this.channels.find(c=> c.qid===qidNum);

            const rate=item.rate || {}

            ;
            const isList= ! !rate.isList;

            // 解析单条价格：fee 可能是数字或 {code, money} 对象
            let singleFee=0;

            if (typeof item.fee==='number') {
                singleFee=item.fee;
            }

            else if (item.fee && typeof item.fee==='object') {
                singleFee=Number(item.fee.money) || 0;
            }

            else {
                const tf=rate.totalFee;
                singleFee=(tf && typeof tf==='object') ? Number(tf.money) || 0 : Number(tf) || 0;
            }

            // 解析多条线路
            let routes=[];

            if (isList && Array.isArray(rate.channelRates)) {
                routes=rate.channelRates.map((r, idx)=> ({
                        key: `cmp_$ {
                            r.entryport || 'LINE'
                        }

                        _$ {
                            r.rateName || idx
                        }

                        _$ {
                            idx
                        }

                        `,
                        rateName: r.rateName || '',
                        entryport: r.entryport || '',
                        zone: r.zone,
                        totalFee: Number(r.totalFee) || 0,
                        notes: r.notes || ''
                    }));
        }

        const minFee=(isList && routes.length) ? Math.min(...routes.map(r=> r.totalFee)) : singleFee;

        return {
            qid: qidNum,
            channelName: (ch && ch.name) || item.wuliu_name || String(qidNum),
            logo: ch ? ch.logo : null,
            currency: (ch && ch.currency) || 'USD',
            isList,
            routes,
            singleFee,
            singleRateName: isList ? '' : (rate.rateName || ''),
            singleEntryport: isList ? '' : (rate.entryport || ''),
            singleZone: isList ? null : (rate.zone !==undefined ? rate.zone : null),
            singleNotes: isList ? '' : (rate.notes || ''),
            minFee
        }

        ;
    });

rows.sort((a, b)=> a.minFee - b.minFee);

return rows.map((r, idx)=> Object.assign({
        rank: idx + 1
    }

    , r));
}

