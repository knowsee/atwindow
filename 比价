// 用地址簿中的 country 字段（可能是 cn_name / short_name / en_name）匹配列表 value
_matchCountryValue(list, raw) {
    if ( !raw) return '';
    const r=raw.trim().toUpperCase();
    const hit=list.find(c=> c.short_name.toUpperCase()===r || c.cn_name===raw || c.en_name.toUpperCase()===r);
    return hit ? hit.value : raw; // 找不到则原样保留（allow-create 兜底）
}

,

_normalizeCompareQids(qids) {
    const existsQids=this.channels.map(c=> Number(c.qid));
    const unique=[];

    (qids || []).forEach(q=> {
            const n=Number(q);

            if (Number.isFinite(n) && existsQids.includes(n) && !unique.includes(n)) {
                unique.push(n);
            }
        });
    return unique;
}

