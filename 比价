/* ══════════════════════════════
             表单校验
          ══════════════════════════════ */
validate() {
    if ( !this.selectedQid) {
        this.$message.warning('请选择一个渠道');
        return false;
    }

    if ( !this.cankaohao.trim()) {
        this.$message.warning('请输入参考号');
        return false;
    }

    const s=this.sender;

    if ( !s.name || !s.province || !s.city || !s.address || !s.postCode || !s.telephone) {
        this.$message.warning('请完善发件人必填信息（姓名、州省、城市、地址1、邮编、电话）');
        return false;
    }

    const r=this.receiver;

    if ( !r.name || !r.province || !r.city || !r.address || !r.postCode || !r.telephone) {
        this.$message.warning('请完善收件人必填信息（姓名、州省、城市、地址1、邮编、电话）');
        return false;
    }

    const p=this.pkg;

    if ( !p.weight || !p.length || !p.width || !p.height) {
        this.$message.warning('请填写包裹的重量和尺寸（长、宽、高）');
        return false;
    }

    if ( !Array.isArray(this.products) || this.products.length===0) {
        this.$message.warning('请至少添加一条货品信息');
        return false;
    }

    for (let i=0; i < this.products.length; i++) {
        const row=this.products[i] || {}

        ;

        const line=`第$ {
            i + 1
        }

        行货品`;

        if ( !String(row.sku || '').trim()) {
            this.$message.warning(`$ {
                    line
                }

                ：请填写SKU`);
            return false;
        }

        if ( !String(row.en_name || '').trim()) {
            this.$message.warning(`$ {
                    line
                }

                ：请填写英文名称`);
            return false;
        }

        if (this.selectedCnNameRequired && !String(row.cn_name || '').trim()) {
            this.$message.warning(`$ {
                    line
                }

                ：请填写中文名称`);
            return false;
        }

        const skuNum=Number(row.sku_num);

        if ( !Number.isFinite(skuNum) || skuNum <=0) {
            this.$message.warning(`$ {
                    line
                }

                ：数量必须大于0`);
            return false;
        }

        const itemWeight=Number(row.weight);

        if ( !Number.isFinite(itemWeight) || itemWeight <=0) {
            this.$message.warning(`$ {
                    line
                }

                ：重量必须大于0`);
            return false;
        }

        if (this.selectedValueRequired) {
            const itemValue=Number(row.value);

            if ( !Number.isFinite(itemValue) || itemValue <=0) {
                this.$message.warning(`$ {
                        line
                    }

                    ：请填写有效的申报价值`);
                return false;
            }
        }
    }

    return true;
}

