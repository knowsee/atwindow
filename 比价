    gap: 8px;
    border: 1px solid #ebeef5;
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 8px;
    background: #fff;
    cursor: pointer;
    transition: border-color .2s, box-shadow .2s;
}

.route-option:hover {
    border-color: #b3d8ff;
}

.route-option.is-selected {
    border-color: #409eff;
    box-shadow: 0 0 0 2px rgba(64, 158, 255, .12);
}

.route-option-main {
    display: flex;
    align-items: center;
    min-width: 0;
    flex: 1;
}

.route-name {
    min-width: 0;
    flex: 1;
    font-size: 13px;
    color: #303133;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.route-price {
    flex: 0 0 auto;
    font-size: 13px;
    color: #67c23a;
    font-weight: 700;
    margin-left: 12px;
}

.order-loading-mask {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 5000;
    display: flex;
    align-items: center;
    justify-content: center;
}

.order-loading-box {
    min-width: 180px;
    padding: 18px 22px;
    border-radius: 10px;
    background: #fff;
    color: #303133;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2);
    font-size: 15px;
    font-weight: 600;
}

.order-loading-box i {
    color: var(--primary);
    font-size: 18px;
}

/* 国家锁定提示 */
.country-lock-tip {
    font-size: 11px;
    color: #e6a23c;
    margin-top: 4px;
}

/* ─── 渠道卡片单选 ─── */
.channel-list {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
}

.channel-card {
    position: relative;
    width: 200px;
    height: 88px;
    border: 2px solid var(--border);
    border-radius: 12px;
    background: #fff;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: all 0.2s;
    overflow: hidden;
    user-select: none;
}

.channel-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 16px rgba(30, 159, 255, 0.15);
}

.channel-card.is-selected {
    border-color: var(--primary);
    background: var(--primary-light);
    box-shadow: 0 4px 16px rgba(30, 159, 255, 0.2);
}

.channel-card.is-primary {
    box-shadow: 0 0 0 2px rgba(103, 194, 58, 0.18), 0 4px 16px rgba(30, 159, 255, 0.2);
}

.channel-card .ch-logo {
    max-width: 120px;
    max-height: 40px;
    object-fit: contain;
}

.channel-card .ch-name {
    font-size: 12px;
    color: var(--text-3);
    font-weight: 500;
}

.channel-card.is-selected .ch-name {
    color: var(--primary);
}

.channel-card .ch-check {
    position: absolute;
    top: 7px;
    right: 7px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
}

.channel-card .ch-check::after {
    content: '';
    width: 5px;
    height: 9px;
    border: 2px solid #fff;
    border-top: none;
    border-left: none;
    transform: rotate(45deg) translateY(-1px);
}

/* 渠道提醒 */
.channel-alert-wrap {
    border: 1px solid #ffe6a3;
    border-radius: 10px;
    background: linear-gradient(180deg, #fffdf6 0%, #fff9eb 100%);
    padding: 14px 16px;
}

.channel-alert-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #8a5a00;
}

.channel-alert-title i {
    font-size: 16px;
}

.channel-alert-content {
    white-space: pre-wrap;
    word-break: break-word;
    color: #6b4a00;
    line-height: 1.8;
    max-height: 260px;
    overflow-y: auto;
    padding-right: 4px;
}

.channel-alert-wrap.is-info {
    border-color: #c6e2ff;
    background: linear-gradient(180deg, #f7fbff 0%, #eff7ff 100%);
}

.channel-alert-wrap.is-info .channel-alert-title,
