    if (this.compareQids.includes(qid)) {
        if (this.compareQids.length <=1) {
            this.$message.warning('比价模式下至少保留一个渠道');
            return;
        }

        this.compareQids=this.compareQids.filter(v=> v !==qid);

        if (this.selectedQid===qid) {
            this.selectedQid=this.compareQids[0];
        }

        return;
    }

    this.compareQids=this._normalizeCompareQids(this.compareQids.concat([qid]));
    this.selectedQid=qid;
}

