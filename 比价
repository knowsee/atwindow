    align-items: center;
    justify-content: space-between;
    gap: 16px;
}

.rate-result-header.is-route-mode {
    justify-content: flex-start;
}

.rate-result-channel {
    display: flex;
    align-items: center;
    gap: 10px;
}

.rate-result-channel .ch-logo-sm {
    max-height: 32px;
    max-width: 80px;
    object-fit: contain;
}

.rate-result-channel strong {
    font-size: 16px;
    color: var(--text-1);
}

.rate-result-channel span {
    font-size: 12px;
    color: var(--text-3);
    margin-left: 4px;
}

.rate-result-price {
    font-size: 32px;
    font-weight: 700;
    color: #67c23a;
    letter-spacing: -0.5px;
}

.rate-result-price small {
    font-size: 15px;
    color: #909399;
    margin-left: 2px;
}

.route-group {
