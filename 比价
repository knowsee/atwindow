    color: #2f63b8;
}

.channel-alert-wrap.is-success {
    border-color: #c8e6c9;
    background: linear-gradient(180deg, #f4fbf4 0%, #edf8ee 100%);
}

.channel-alert-wrap.is-success .channel-alert-title,
.channel-alert-wrap.is-success .channel-alert-content {
    color: #276749;
}

.channel-alert-wrap.is-error {
    border-color: #f8c9c9;
    background: linear-gradient(180deg, #fff7f7 0%, #fff0f0 100%);
}

.channel-alert-wrap.is-error .channel-alert-title,
.channel-alert-wrap.is-error .channel-alert-content {
    color: #b42318;
}

.compare-mode-tip {
    margin-bottom: 12px;
    padding: 8px 12px;
    background: #f0f9ff;
    border: 1px solid #c6e2ff;
    border-radius: 8px;
    color: #2f63b8;
    font-size: 12px;
}

/* 比价结果卡片列表 */
.compare-result-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.compare-channel-card {
    border: 1.5px solid #ebeef5;
    border-radius: 10px;
    overflow: hidden;
    transition: box-shadow .2s;
}

.compare-channel-card.is-best {
    border-color: #67c23a;
}

.compare-ch-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: #fafafa;
    border-bottom: 1px solid #f0f0f0;
}

.compare-channel-card.is-best .compare-ch-header {
    background: linear-gradient(135deg, #f0f9eb, #e8f5e9);
}

.compare-ch-rank {
    font-size: 15px;
    font-weight: 700;
    color: #c0c4cc;
    min-width: 26px;
}

.compare-ch-rank.is-gold {
    color: #e6a23c;
}

.compare-ch-rank.is-silver {
    color: #909399;
}

.compare-ch-rank.is-bronze {
    color: #a97c50;
}

.compare-ch-logo {
    max-height: 28px;
    max-width: 70px;
    object-fit: contain;
}

.compare-ch-name {
    font-size: 14px;
    color: #303133;
}

.compare-route-row {
    display: flex;
    align-items: center;
    padding: 11px 16px;
    gap: 12px;
    border-bottom: 1px solid #f5f5f5;
    transition: background .15s;
}

.compare-route-row:last-child {
    border-bottom: none;
}

.compare-route-row:hover {
    background: #f5f8ff;
}

.compare-route-info {
    flex: 1;
    min-width: 0;
}

.compare-route-name {
    font-size: 13px;
    color: #303133;
    font-weight: 600;
}

.compare-route-notes {
    font-size: 11px;
    color: #909399;
    margin-top: 3px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.compare-route-price {
    font-size: 20px;
    font-weight: 700;
    color: #67c23a;
    white-space: nowrap;
    flex: 0 0 auto;
}

.compare-route-price small {
    font-size: 12px;
    color: #909399;
    margin-left: 2px;
}

@media (max-width: 640px) {
    .channel-card {
        width: calc(50% - 8px);
    }
}

/* 货品表格表头样式 */
.products-table th.el-table__cell {
    background: #f0f5ff !important;
    color: #3c6cce;
    font-weight: 600;
    font-size: 13px;
    border-bottom: 2px solid #d0e0ff;
}

.el-form-item__label {
    font-weight: 500;
    color: var(--text-1);
}

.el-input__inner,
.el-textarea__inner {
    border-radius: 6px;
}

/* Dialog 遮罩层修复：iframe 嵌入兼容——遮罩锚定到 #app 容器内，避免覆盖父框架 */
#app {
    position: relative;
    min-height: 100vh;
}

.el-dialog__wrapper {
    position: absolute !important;
