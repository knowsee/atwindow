// 保证 token 可用
if (typeof token==='undefined') {
    window.token=localStorage.getItem('token') || '';
}

// API 地址（使用 common.js 中已定义的 baseUrl，向下兼容）
const _base=(typeof baseUrl !=='undefined') ? baseUrl : 'https://backend.atwindow.com/api';
const RATE_URL=_base+'/ordernew/newbillRate';
const ORDER_URL=_base+'/ordernew/newbillOrder';
const ADDR_URL=(window.common && window.common.queryAddr) || (_base + '/order/queryAddr');
const BEIAN_ADDR_URL=(window.common && window.common.beianAddr) || (_base + '/order/beianAddr');

// ============================================================
//  Vue 实例初始化（等待 Vue + Element UI 加载完毕）
// ============================================================
function initApp() {
    if (typeof Vue==='undefined' || typeof ELEMENT==='undefined') {
        setTimeout(initApp, 50);
        return;
    }

    window.app=new Vue({
        el: '#app',

        data() {
            return {
                /* ---- 配置透传 ---- */
                channels: PAGE_CONFIG.channels,
                channelAlerts: CHANNEL_ALERT_CONFIG,

                /* ---- 渠道选择（单选，默认第一个） ---- */
                selectedQid: PAGE_CONFIG.channels[0] ? PAGE_CONFIG.channels[0].qid : null,
                compareMode: false,
                compareQids: PAGE_CONFIG.channels[0] ? [PAGE_CONFIG.channels[0].qid] : [],

                /* ---- 基础信息 ---- */
                danwei: 0, // 0=g/cm  1=lb/in
                cankaohao: '',

                /* ---- 发件人 ---- */
                sender: {
                    name: '', country: '',
                    province: '', city: '', address: '', address2: '',
                    postCode: '', telephone: '', company: ''
                }

                ,

                /* ---- 收件人 ---- */
                receiver: {
                    name: '', country: '',
                    province: '', city: '', address: '', address2: '',
                    postCode: '', telephone: '', company: ''
                }

                ,

                /* ---- 包裹（单包裹） ---- */
                pkg: {
                    weight: '', length: '', width: '', height: ''
                }

                ,

                /* ---- 货品列表 ---- */
                products: [ {
                    sku: '', sku_num: 1, en_name: '', cn_name: '', weight: '', value: ''
                }

                ],

                /* ---- 国家列表 ---- */
                senderCountryList: [],
                receiverCountryList: [],

                /* ---- 地址弹窗 ---- */
                addrDialogVisible: false,
                addrDialogTarget: 'sender',
                addrList: [],
                addrTotal: 0,
                addrCurrentPage: 1,
                addrPageSize: 10,
                addrSearchName: '',
                addrLoading: false,

                /* ---- 报价 ---- */
                rateLoading: false,
                rateBest: null, // res.data
                rateDetail: null, // res.data.rate_list[0]
                rateCompareList: [],
                routeOptions: [],
                selectedRouteKey: '',

                /* ---- 提交 ---- */
                submitting: false,
                orderLoading: false
            }

            ;
        }

        ,

        computed: {
            unitLabel() {
                return this.danwei===0 ? {
                    w: 'g', l: 'cm'
                }

                : {
                    w: 'lb', l: 'in'
                }

                ;
            }

            ,
            selectedCurrency() {
                const ch=this.channels.find(c=> c.qid===this.selectedQid);
                return (ch && ch.currency) ? ch.currency : 'USD';
            }

            ,
            selectedChannelLogo() {
                const ch=this.channels.find(c=> c.qid===this.selectedQid);
                return ch ? ch.logo : null;
            }

            ,
            selectedChannelName() {
                const ch=this.channels.find(c=> c.qid===this.selectedQid);
                return ch ? ch.name : '';
            }

            ,
            selectedValueRequired() {
                const ch=this.channels.find(c=> c.qid===this.selectedQid);
                return ch ? ! !ch.valueRequired : false;
            }

            ,
            selectedNeedRouteSelect() {
                const ch=this.channels.find(c=> c.qid===this.selectedQid);
                return ch ? ! !ch.needRouteSelect : false;
            }

            ,
            selectedCnNameRequired() {
                const ch=this.channels.find(c=> c.qid===this.selectedQid);
                return ch ? (ch.cnNameRequired !==false) : true;
            }

            ,
            senderCountryLock() {
                const ch=this.channels.find(c=> c.qid===this.selectedQid);
                return ch ? (ch.senderCountryLock || null) : null;
            }

            ,
            receiverCountryLock() {
                const ch=this.channels.find(c=> c.qid===this.selectedQid);
                return ch ? (ch.receiverCountryLock || null) : null;
            }

            ,
            senderNeedBeianAddr() {
                const ch=this.channels.find(c=> c.qid===this.selectedQid);
                return ch ? ! !ch.senderNeedBeianAddr : false;
            }

            ,
            selectedChannelAlert() {
                if ( !this.channelAlerts) return null;
                return this.channelAlerts[this.selectedQid] || this.channelAlerts.default || null;
            }

            ,
            hasRateResult() {
                return this.compareMode ? this.rateCompareList.length > 0 : ! !this.rateBest;
            }

            ,
            selectedRoute() {
                return this.routeOptions.find(r=> r.key===this.selectedRouteKey) || null;
            }
        }

        ,

        watch: {

            // 切换渠道时，若新渠道有国家锁定则自动回填
            selectedQid() {
                this.routeOptions=[];
                this.selectedRouteKey='';
                this.rateBest=null;
                this.rateDetail=null;
                this.rateCompareList=[];

                if (this.compareMode && !this.compareQids.includes(this.selectedQid)) {
                    this.compareQids=this._normalizeCompareQids(this.compareQids.concat([this.selectedQid]));
                }

                if (this.senderCountryLock && this.senderCountryList.length) {
                    this.sender.country=this._matchCountryValue(this.senderCountryList, this.senderCountryLock);
                }

                if (this.receiverCountryLock && this.receiverCountryList.length) {
                    this.receiver.country=this._matchCountryValue(this.receiverCountryList, this.receiverCountryLock);
                }
            }

            ,

            compareMode(v) {
                if (v) {
                    this.compareQids=this._normalizeCompareQids(this.compareQids.concat([this.selectedQid]));
                }

                else {
                    this.compareQids=this.selectedQid ? [this.selectedQid] : [];
                }

                this.rateBest=null;
                this.rateDetail=null;
                this.rateCompareList=[];
                this.routeOptions=[];
                this.selectedRouteKey='';
            }
        }

        ,

        mounted() {
            this.loadSenderCountries();
            this.loadReceiverCountries();
        }

        ,

        methods: {

            /* ══════════════════════════════
             国家列表加载
          ══════════════════════════════ */
            _buildCountryOptions(countryList) {
                return countryList.map(c=> ({
                        value: c.short_name || c.cn_name,
                        label: [c.short_name, c.en_name, c.cn_name].filter(Boolean).join(' - '),
                        short_name: c.short_name || '',
                        cn_name: c.cn_name || '',
                        en_name: c.en_name || ''
                    }));
        }

        ,

        loadSenderCountries() {
            const url=(window.common && window.common.queryCountry) || (_base + '/order/queryCountry');

            $.ajax({

                type: 'post', url,
                data: {
                    token: window.token
                }

                ,
                success: (res)=> {
                    if (res.code==1 && res.data) {
                        this.senderCountryList=this._buildCountryOptions(res.data);

                        // 若有锁定国家，初始化 sender.country
                        if (this.senderCountryLock) {
                            this.sender.country=this._matchCountryValue(this.senderCountryList, this.senderCountryLock);
                        }
                    }
                }
            });
    }

    ,

    loadReceiverCountries() {
        const url=(window.common && window.common.queryCountry) || (_base + '/order/queryCountry');

        $.ajax({

