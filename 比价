/* ══════════════════════════════
             提取费用/运价条目（用于表格显示）
          ══════════════════════════════ */
getFeeEntries(item) {
    const src=(item.fee && Object.keys(item.fee).length) ? item.fee : (item.rate && Object.keys(item.rate).length) ? item.rate : null;
    if ( !src) return [];

    const entries=[];

    for (const k in src) {
        const v=src[k];
        const numVal=parseFloat(v);

        if ( !isNaN(numVal)) {
            entries.push({
                key: k,
                label: k.replace(/_/g, ' '),
                value: numVal.toFixed(2),
                isTotal: /total/i.test(k)
            });
    }
}

// 总价排到最后
entries.sort((a, b)=> (a.isTotal ? 1 : 0) - (b.isTotal ? 1 : 0));
return entries;
}

