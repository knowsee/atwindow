buildPayload(qidStr, routeInfo) {
    // 收件人国家：从列表中取出英文简写（short_name）和中文名（cn_name）
    const recCntOpt=this.receiverCountryList.find(c=> c.value===this.receiver.country);
    const recCntShort=recCntOpt ? (recCntOpt.short_name || recCntOpt.value) : this.receiver.country;
    const recCntCn=recCntOpt ? recCntOpt.cn_name : '';
    // routeInfo 来自比价直接下单；undefined 时回退到 selectedRoute 计算属性
    const selectedRoute=(routeInfo !==undefined) ? routeInfo : this.selectedRoute;

    const extraPayload= {
        source: 'web'
    }

    ;

    if (selectedRoute) {
        extraPayload.route= {
            rateName: selectedRoute.rateName,
            entryport: selectedRoute.entryport,
            zone: selectedRoute.zone,
            totalFee: selectedRoute.totalFee
        }

        ;
    }

    const payload= {
        token: window.token,
        cankaohao: this.cankaohao,
        danwei: this.danwei,
        qid: qidStr !==undefined ? String(qidStr) : String(this.selectedQid),
        extra: extraPayload,

        package_info: [ {
            weight: Number(this.pkg.weight) || 0,
            length: Number(this.pkg.length) || 0,
            width: Number(this.pkg.width) || 0,
            height: Number(this.pkg.height) || 0
        }

        ],

        product_info: this.products.map(p=> ({
                sku: p.sku,
                sku_num: Number(p.sku_num) || 1,
                en_name: p.en_name,
                cn_name: p.cn_name,
                weight: Number(p.weight) || 0,
                value: Number(p.value) || 0
            })),

    'send-people-name': this.sender.name,
    'send-people-country': this.sender.country,
    'send-people-province': this.sender.province,
    'send-people-city': this.sender.city,
    'send-people-address': this.sender.address,
    'send-people-address2': this.sender.address2,
    'send-people-postCode': this.sender.postCode,
    'send-people-telephone': this.sender.telephone,

    'rec-people-name': this.receiver.name,
    'rec-people-country': recCntShort, // 英文简写，如 US / DE
    'rec-people-country-name': recCntCn, // 中文名，如 美国 / 德国
    'rec-people-province': this.receiver.province,
    'rec-people-city': this.receiver.city,
    'rec-people-address': this.receiver.address,
    'rec-people-address2': this.receiver.address2,
    'rec-people-postCode': this.receiver.postCode,
    'rec-people-telephone': this.receiver.telephone,
    'rec-people-company': this.receiver.company,
    '_orderaction': 'create'
}

;

// 顶层冗余线路字段，兼容后端只读取一级参数的场景
if (selectedRoute) {
    payload.rateName=selectedRoute.rateName || '';
    payload.entryport=selectedRoute.entryport || '';
    payload.zone=selectedRoute.zone;
    payload.totalFee=selectedRoute.totalFee;
}

return payload;
}

