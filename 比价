    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    height: 100% !important;
}

.v-modal {
    position: absolute !important;
    z-index: 2999 !important;
    top: 0 !important;
    left: 0 !important;
