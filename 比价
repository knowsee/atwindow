/* ══════════════════════════════
             试算运费
          ══════════════════════════════ */
doRate() {
    if ( !this.validate()) return;

    const qidList=this.compareMode ? this._normalizeCompareQids(this.compareQids) : [this.selectedQid];

    if ( !qidList.length) {
        this.$message.warning('请选择至少一个渠道进行试算');
        return;
    }

    if (this.compareMode) {
        this.compareQids=qidList;

        if ( !qidList.includes(this.selectedQid)) {
            this.selectedQid=qidList[0];
        }
    }

    this.rateLoading=true;
    this.rateBest=null;
    this.rateDetail=null;
    this.rateCompareList=[];
    this.routeOptions=[];
    this.selectedRouteKey='';

    $.ajax({

        type: 'post',
        url: RATE_URL,
        data: JSON.stringify(this.buildPayload(qidList.join(','))),
        contentType: 'application/json;charset=utf-8',
        headers: {
            token: window.token
        }

        ,
        success: (res)=> {
            this.rateLoading=false;

            if (res.code==1 && res.data) {
                if (this.compareMode) {
                    this.rateCompareList=this._extractCompareRateList(res.data);

                    if ( !this.rateCompareList.length) {
                        this.$message.warning('比价请求成功，但未返回可展示的渠道报价数据');
                    }

                    else {
                        this.$message.success('比价获取成功');
                    }
                }

                else {
                    this.rateBest=res.data;
                    const list=Array.isArray(res.data.rate_list) ? res.data.rate_list : [];
                    this.rateDetail=list.length > 0 ? list[0] : null;

                    if (this.selectedNeedRouteSelect) {
                        this.routeOptions=this._extractRouteOptions(res.data);

                        if ( !this.routeOptions.length) {
                            this.$message.warning('该渠道需要选择线路，但报价未返回可选线路，请检查地址和包裹信息');
                        }
                    }

                    this.$message.success('报价获取成功');
                }

                this.$nextTick(()=> {
                        const el=document.getElementById('rate-section');

                        if (el) el.scrollIntoView({
                            behavior: 'smooth', block: 'start'
                        });
                });
        }

        else {
            this.$message.error(res.msg || '试算失败，请检查填写内容');
        }
    }

    ,
    error: ()=> {
        this.rateLoading=false;
        this.$message.error('网络请求失败，请重试');
    }
});
}

