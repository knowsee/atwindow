    2004: {
        type: 'warning',
            title: 'DHLe 报价提醒',
            content: '使用DHLe渠道请首先联络我们客服代表，由于DHLe需要自行送件以及需提前预约、DSM生成申报等手续，请务必了解清楚后再次使用。'
    }
}

;
