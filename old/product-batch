        /* 判断 编辑 查看 添加 */
        function checkType() {
            if (type == "detail" || type == "edit") {
                requestPost(common.detailPro, { id: id }, function (res) {
                    if (res.code == 1) {
                        console.log(res);

                        var data = res.data;
                        form.val("form", data);


                        if (/(http|https):\/\/([\w.]+\/?)\S*/.test(data.img_url)) {
                            $("#upload_pro")
                                .parent()
                                .find(".img_box img")
                                .attr("src", data.img_url || "/images/no-image.gif");
                        } else {
                            $("#upload_pro")
                                .parent()
                                .find(".img_box img")
                                .attr("src", imgUrl + data.img_url || "/images/no-image.gif");
                        }

                        if (/(http|https):\/\/([\w.]+\/?)\S*/.test(data.certificate_url)) {
                            $("#upload_zs")
                                .parent()
                                .find(".img_box img")
                                .attr(
                                    "src",
                                    data.certificate_url || "/images/no-image.gif"
                                );
                        } else {
                            $("#upload_zs")
                                .parent()
                                .find(".img_box img")
                                .attr(
                                    "src",
                                    imgUrl + data.certificate_url || "/images/no-image.gif"
                                );
                        }


                    }
                    if (data.yxtime == 0) {
                        $("#time").val("");
                    } else {
                        laydate.render({
                            elem: "#time",
                            value: data.yxtime
                        });
                    }


                    var select = 'dd[lay-value=' + data.cat_id + ']';
                    $("select[name='cat_id']").siblings("div.layui-form-select").find('dl').find(select).click();





                    if (type == "detail") {
                        $("button").hide();
                        $("input,select").attr("disabled", true);
                        // $(".cz").hide();

                        $(".layui-btn-normal").hide()
                    }
                    $(".layui-tab-title").hide();
                    $(".back").show()
                    form.render();
                });
            }
        }
